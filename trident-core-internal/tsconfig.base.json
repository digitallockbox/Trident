{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["packages/*/src", "packages/engine-shared"],
  "references": [
    { "path": "packages/engine-shared" },
    { "path": "packages/internal-omega" },
    { "path": "packages/internal-aegis" },
    { "path": "packages/internal-overwatch" }
  ]
}
