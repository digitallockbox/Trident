# Docker Environment Variables

# Backend (.env)
PORT=3000
NODE_ENV=production
DATABASE_URL=postgresql://postgres:password@db:5432/trident
JWT_SECRET=change-this-to-a-strong-secret-in-production
API_KEY=change-this-to-a-strong-api-key-in-production

# Database
POSTGRES_PASSWORD=change-this-password-in-production
POSTGRES_USER=postgres
POSTGRES_DB=trident
