PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/trident
JWT_SECRET=your-secret-key-here
API_KEY=your-api-key-here
TRIDENT_JWT_SECRET=your-trident-jwt-secret-here
TRIDENT_AUDIT_RETENTION_DAYS=365

# Solana RPC endpoint (use a reliable provider or your own node)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Treasury keypair (JSON array or base58 string, never commit real key!)
# Example (JSON array):
# SOLANA_TREASURY_KEYPAIR=[12,34,56,...,99]
# Example (base58):
# SOLANA_TREASURY_KEYPAIR=3v1b... (output of solana-keygen)
SOLANA_TREASURY_KEYPAIR=
